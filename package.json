{
  "name": "sailpoint-developer-portal",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start --port=4201",
    "start-minified": "docusaurus start --config docusaurus.config.minified.ts --port=4202",
    "start-extensibility": "docusaurus start --config docusaurus.config.extensibility.ts --port=4203",
    "build": "docusaurus build",
    "build-minified": "docusaurus build --config docusaurus.config.minified.ts",
    "build-extensibility": "docusaurus build --config docusaurus.config.extensibility.ts",
    "build:rspack:trace": "DOCUSAURUS_RSPACK_TRACE=true DOCUSAURUS_DISABLE_LAST_UPDATE=true DOCUSAURUS_EXIT_AFTER_BUNDLING=true npm run build",
    "build:profile:bundling": "samply record -- DOCUSAURUS_EXIT_AFTER_BUNDLING=true node --perf-prof --perf-basic-prof --interpreted-frames-native-stack ./node_modules/@docusaurus/core/bin/docusaurus.mjs build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve --port=4200",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "gen-api-docs": "docusaurus gen-api-docs",
    "clean-api-docs": "docusaurus clean-api-docs",
    "gen-api-docs:version": "docusaurus gen-api-docs:version",
    "clean-api-docs:version": "docusaurus clean-api-docs:version",
    "gen-api-docs-all": "docusaurus gen-api-docs isc_versioned --plugin-id isc-api && docusaurus gen-api-docs iiq --plugin-id iiq-api && docusaurus gen-api-docs:version nerm_versioned:all --plugin-id nerm-api && docusaurus gen-api-docs nerm_versioned --plugin-id nerm-api",
    "clean-api-docs-all": "docusaurus clean-api-docs isc_versioned --plugin-id isc-api && docusaurus clean-api-docs nerm_versioned --plugin-id nerm-api && docusaurus clean-api-docs:version nerm_versioned:all --plugin-id nerm-api",
    "rebuild-docs": "npm run clean-api-docs-all && npm run gen-api-docs-all",
    "sync-sdk-docs": "bash scripts/sync-sdk-docs-local.sh",
    "sync-sdk-docs:skip-build": "bash scripts/sync-sdk-docs-local.sh --skip-build",
    "setup": "bash scripts/setup.sh",
    "v1-merge-code-examples": "node src/components/mergeoverlayfiles.js static/code-examples/v1/python_code_examples_overlay.yaml static/code-examples/v1/powershell_code_examples_overlay.yaml static/code-examples/v1/go_code_examples_overlay.yaml static/code-examples/v1/typescript_code_examples_overlay.yaml",
    "overlay-code-examples-v1": "node src/components/overlay.js static/api-specs/idn/sailpoint-api.yaml static/code-examples/v1/merged_code_examples.yaml",
    "nerm-merge-code-examples": "node src/components/mergeoverlayfiles.js static/code-examples/nerm/python_code_examples_overlay.yaml static/code-examples/nerm/powershell_code_examples_overlay.yaml static/code-examples/nerm/go_code_examples_overlay.yaml static/code-examples/nerm/typescript_code_examples_overlay.yaml",
    "overlay-code-examples-nerm": "node src/components/overlay.js static/api-specs/nerm/openapi.yaml static/code-examples/nerm/merged_code_examples.yaml",
    "merge-all-code-examples": "npm run v1-merge-code-examples && npm run nerm-merge-code-examples",
    "gen-all-api-specs-code-examples": "npm run overlay-code-examples-v1"
  },
  "dependencies": {
    "@docusaurus/faster": "3.9.2",
    "@docusaurus/logger": "3.9.2",
    "@docusaurus/plugin-client-redirects": "3.9.2",
    "@docusaurus/plugin-content-blog": "3.9.2",
    "@docusaurus/plugin-content-docs": "3.9.2",
    "@docusaurus/plugin-content-pages": "3.9.2",
    "@docusaurus/plugin-google-tag-manager": "3.9.2",
    "@docusaurus/theme-classic": "3.9.2",
    "@docusaurus/theme-common": "3.9.2",
    "@docusaurus/theme-mermaid": "3.9.2",
    "@docusaurus/utils": "3.9.2",
    "@docusaurus/utils-common": "3.9.2",
    "@docusaurus/utils-validation": "3.9.2",
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@fortawesome/fontawesome-free": "^7.0.0",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@gracefullight/docusaurus-plugin-microsoft-clarity": "^1.0.0",
    "@mdx-js/react": "^3.0.0",
    "@mui/material": "^6.1.6",
    "@reduxjs/toolkit": "^2.11.2",
    "@typeform/embed-react": "^1.21.0",
    "ace-builds": "^1.36.4",
    "autoprefixer": "^10.4.13",
    "canvas-confetti": "^1.9.3",
    "classnames": "^2.3.2",
    "clsx": "^2.0.0",
    "docusaurus-plugin-openapi-docs": "4.7.1",
    "docusaurus-theme-openapi-docs": "4.7.1",
    "jsonpathly": "github:sailpoint-oss/jsonpathly#v2.2.0",
    "ldrs": "^1.0.1",
    "path-browserify": "^1.0.1",
    "prism-react-renderer": "^2.3.0",
    "react": "^18.2.0",
    "react-ace": "^13.0.0",
    "react-dom": "^18.2.0",
    "react-live": "^4.0.0",
    "react-markdown": "^8.0.7",
    "react-spinners": "^0.13.8",
    "react-tabs": "^4.3.0",
    "velocityjs": "^2.1.5"
  },
  "overrides": {
    "mermaid": "10.9.3",
    "jsonpointer": "5.0.0",
    "marked": "^4.3.0",
    "yargs-parser": "^21.0.1",
    "dompurify": "^3.0.8",
    "ejs": "^3.1.10",
    "nconf": "^0.11.4"
  },
  "devDependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/module-type-aliases": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@docusaurus/tsconfig": "3.9.2",
    "@docusaurus/types": "3.9.2",
    "@types/js-yaml": "^4.0.9",
    "dotenv": "^16.4.5",
    "esbuild": "^0.25.0",
    "husky": "^8.0.2",
    "js-yaml": "^4.1.1",
    "prettier": "2.8.0",
    "pretty-quick": "^3.1.3",
    "speccy": "^0.11.0",
    "typescript": "~5.6.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged"
    }
  }
}
